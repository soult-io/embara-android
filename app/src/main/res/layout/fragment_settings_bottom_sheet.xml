<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/trek_bg"
    android:paddingBottom="16dp">

    <!-- Drag handle -->
    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bottom_sheet_handle" />

    <!-- Server section -->
    <LinearLayout
        android:id="@+id/sheet_change_server"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/settings_change_server_title"
        android:background="?android:attr/selectableItemBackground"
        android:paddingHorizontal="24dp"
        android:paddingVertical="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_server"
            android:textSize="16sp"
            android:textColor="@color/trek_text" />

        <TextView
            android:id="@+id/sheet_current_url"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/trek_text_secondary"
            android:paddingTop="2dp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1a4a90d9"
        android:layout_marginHorizontal="24dp" />

    <!-- Clear cache -->
    <LinearLayout
        android:id="@+id/sheet_clear_cache"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/settings_clear_cache_title"
        android:background="?android:attr/selectableItemBackground"
        android:paddingHorizontal="24dp"
        android:paddingVertical="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_clear_cache_title"
            android:textSize="16sp"
            android:textColor="@color/trek_text" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_clear_cache_desc"
            android:textSize="13sp"
            android:textColor="@color/trek_text_secondary"
            android:paddingTop="2dp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1a4a90d9"
        android:layout_marginHorizontal="24dp" />

    <!-- About -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingVertical="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_about"
            android:textSize="16sp"
            android:textColor="@color/trek_text" />

        <TextView
            android:id="@+id/sheet_version_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/trek_text_secondary"
            android:paddingTop="2dp" />

    </LinearLayout>

</LinearLayout>
