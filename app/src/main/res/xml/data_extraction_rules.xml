<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="embara_prefs.xml"/>
        <!-- WebView data (Cookies SQLite + Local Storage) lives at the data-dir root in
             app_webview/. Exclude it so auth state never round-trips through backup/restore
             and can't clobber the live logged-in session (#2358). -->
        <exclude domain="root" path="app_webview/"/>
    </cloud-backup>
    <device-transfer>
        <!-- Allowlist: only embara_prefs is transferred, so app_webview/ (auth/cookies)
             is already excluded — an explicit <exclude> here is redundant and lint-invalid. -->
        <include domain="sharedpref" path="embara_prefs.xml"/>
    </device-transfer>
</data-extraction-rules>
